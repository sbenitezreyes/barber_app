rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Documentos de verificación de identidad ────────────────────
    // Solo el propio usuario puede leer/escribir sus documentos.
    // El Admin SDK (Cloud Functions) tiene acceso completo sin pasar por estas reglas.
    match /identity_verification/{userId}/{file} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024  // máx 10 MB
        && request.resource.contentType.matches('image/.*');
    }

    // ── Fotos de perfil (ruta usada por la app) ────────────────────
    match /users/{userId}/profile/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ── Portafolio (ruta usada por la app) ─────────────────────────
    match /users/{userId}/portfolio/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ── Ruta antigua opcional (si aun la usan) ─────────────────────
    match /barber_photos/{userId}/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
