rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles ──────────────────────────────────────────
    // Full read/write for own document subtree
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Other authenticated users can read the top-level profile
    match /users/{userId} {
      allow read: if request.auth != null;

      // Clientes anónimos y nuevos usuarios pueden crear su propio documento
      // (necesario para guardar el token FCM antes del registro)
      allow create: if request.auth != null && request.auth.uid == userId;

      // Client can update rating/ratingCount only (for review recalculation)
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['rating', 'ratingCount']);

      // Barber's own profile updates: token refresh, location, liveRoute, availability, schedule
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['fcmToken', 'location', 'liveRoute', 'isAvailable', 'schedule']);

      // User submits for identity verification (only allowed to set status → 'pending')
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['verificationStatus', 'verificationSubmittedAt'])
        && request.resource.data.verificationStatus == 'pending';
    }

    // ── Services (read-only for clients) ──────────────────────
    match /users/{userId}/services/{serviceId} {
      allow read: if request.auth != null;
    }

    // ── Reviews ───────────────────────────────────────────────
    match /users/{userId}/reviews/{reviewId} {
      allow read: if request.auth != null;
      // Create: el clientUid del documento debe coincidir con el usuario autenticado
      allow create: if request.auth != null
        && request.resource.data.clientUid == request.auth.uid;
      // Delete: solo el autor puede eliminar su reseña
      allow delete: if request.auth != null
        && resource.data.clientUid == request.auth.uid;
    }

    // ── Barber notes about clients (anonymous, barbers only) ──
    // Stored under the client's user doc; not shown in the client app.
    match /users/{userId}/barberReviews/{reviewId} {
      allow read, write: if request.auth != null;
    }

    // ── Appointments ──────────────────────────────────────────
    match /appointments/{appointmentId} {
      // Any authenticated user can create (client books an appointment)
      allow create: if request.auth != null;

      // Both client and barber can read their own appointments
      allow read: if request.auth != null
        && (resource.data.clientUid == request.auth.uid
            || resource.data.barberUid == request.auth.uid);

      // Barber can update status, GPS coordinates, departure flag, and cancelledBy when cancelling
      allow update: if request.auth != null
        && resource.data.barberUid == request.auth.uid
        && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['status', 'barberCurrentLat', 'barberCurrentLng', 'cancelledBy', 'barberDeparting', 'barberDepartingEtaMin'])
        && (!request.resource.data.keys().hasAny(['status']) ||
            request.resource.data.status in ['confirmed', 'en_servicio', 'completed', 'missed', 'cancelled', 'rejected']);

      // Client can cancel their own appointment (status → 'cancelled' + cancelledBy)
      allow update: if request.auth != null
        && resource.data.clientUid == request.auth.uid
        && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['status', 'cancelledBy'])
        && request.resource.data.status == 'cancelled';
    }
  }
}
