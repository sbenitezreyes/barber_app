rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles ──────────────────────────────────────────
    // Full read/write for own document subtree
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Other authenticated users can read the top-level profile
    match /users/{userId} {
      allow read: if request.auth != null;

      // Client can update rating/ratingCount only (for review recalculation)
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['rating', 'ratingCount']);

      // Barber's own token refresh (fcmToken only)
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['fcmToken']);
    }

    // ── Services (read-only for clients) ──────────────────────
    match /users/{userId}/services/{serviceId} {
      allow read: if request.auth != null;
    }

    // ── Reviews (anonymous, docId = reviewerUid) ──────────────
    match /users/{userId}/reviews/{reviewId} {
      allow read: if request.auth != null;
      // Only the reviewer can write (create/update/delete) their own review
      allow write: if request.auth != null && request.auth.uid == reviewId;
    }

    // ── Appointments ──────────────────────────────────────────
    match /appointments/{appointmentId} {
      // Any authenticated user can create (client books an appointment)
      allow create: if request.auth != null;

      // Both client and barber can read their own appointments
      allow read: if request.auth != null
        && (resource.data.clientUid == request.auth.uid
            || resource.data.barberUid == request.auth.uid);

      // Barber can update status and GPS coordinates
      allow update: if request.auth != null
        && resource.data.barberUid == request.auth.uid
        && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['status', 'barberCurrentLat', 'barberCurrentLng']);

      // Client can cancel their own appointment (status → 'cancelled')
      allow update: if request.auth != null
        && resource.data.clientUid == request.auth.uid
        && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['status'])
        && request.resource.data.status == 'cancelled';
    }
  }
}
